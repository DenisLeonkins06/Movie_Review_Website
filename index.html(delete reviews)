    <script>
        // ── Default reviews (used only on first load if localStorage is empty) ──
        const DEFAULT_REVIEWS = [
            {
                id: 1,
                author: "Sean M.",
                movie: "Oppenheimer",
                stars: "★★★★★",
                text: "Absolutely brilliant film. Nolan at his best. The cast was incredible and the pacing kept me hooked for the full 3 hours."
            },
            {
                id: 2,
                author: "Aoife K.",
                movie: "Dune: Part Two",
                stars: "★★★★☆",
                text: "Visually stunning. The desert scenes were insane. Lost a star because the ending felt a bit rushed."
            },
            {
                id: 3,
                author: "Conor D.",
                movie: "Parasite",
                stars: "★★★★★",
                text: "One of the best films I've ever seen. The twist halfway through completely changed everything. A must-watch."
            }
        ];

        // ── State ──
        let currentUser = localStorage.getItem('flickCurrentUser') || 'guest';
        let reviews = loadReviews();

        // ── Load / Save helpers ──
        function loadReviews() {
            const stored = localStorage.getItem('flickReviews');
            return stored ? JSON.parse(stored) : [...DEFAULT_REVIEWS];
        }

        function saveReviews() {
            localStorage.setItem('flickReviews', JSON.stringify(reviews));
        }

        // ── Auth ──
        function switchUser(val) {
            currentUser = val;
            localStorage.setItem('flickCurrentUser', val);
            document.getElementById('current-user-label').textContent =
                val === 'guest' ? 'Guest' : val;
            renderReviews();
        }

        function canDelete(review) {
            return currentUser === 'admin' || currentUser === review.author;
        }

        // ── Render ──
        function renderReviews() {
            const list = document.getElementById('review-list');
            list.innerHTML = '';

            if (reviews.length === 0) {
                list.innerHTML = '<p class="no-reviews">No reviews yet. Be the first to write one!</p>';
                return;
            }

            reviews.forEach(review => {
                const item = document.createElement('div');
                item.className = 'review-item';
                item.dataset.id = review.id;

                item.innerHTML = `
                    <div class="review-header">
                        <strong>${escapeHtml(review.author)}</strong>
                        <span class="review-movie">${escapeHtml(review.movie)}</span>
                        <span class="review-stars">${review.stars}</span>
                    </div>
                    <p>"${escapeHtml(review.text)}"</p>
                    ${canDelete(review)
                        ? `<button class="delete-btn" title="Delete review" onclick="deleteReview(${review.id}, this)">🗑️</button>`
                        : ''}
                `;
                list.appendChild(item);
            });
        }

        // ── Delete ──
        function deleteReview(id, btn) {
            const item = btn.closest('.review-item');

            // Animate out, then remove
            item.classList.add('removing');
            item.addEventListener('animationend', () => {
                reviews = reviews.filter(r => r.id !== id);
                saveReviews();
                renderReviews();
            }, { once: true });
        }

        // ── Utility: prevent XSS ──
        function escapeHtml(str) {
            return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        // ── Init ──
        document.getElementById('user-switcher').value = currentUser;
        switchUser(currentUser);
    </script>

</body>
