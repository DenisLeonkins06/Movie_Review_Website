    <link rel="stylesheet" href="style.css">
    <style>
        /* --- Auth Bar --- */
        .auth-bar {
            background: #0a0a1a;
            padding: 8px 32px;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 12px;
            font-size: 0.85rem;
            color: #aaa;
            border-bottom: 1px solid #1e1e3a;
        }
        .auth-bar select, .auth-bar button {
            background: #1a1a2e;
            color: #eee;
            border: 1px solid #333;
            border-radius: 6px;
            padding: 4px 10px;
            cursor: pointer;
            font-size: 0.82rem;
        }
        .auth-bar button:hover { background: #e74c3c; border-color: #e74c3c; }
        .auth-user { color: #f0c040; font-weight: 600; }

        /* --- Review item layout --- */
        .review-item {
            position: relative;
            padding-right: 48px;
        }
        .delete-btn {
            position: absolute;
            top: 50%;
            right: 12px;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1.1rem;
            opacity: 0.35;
            transition: opacity 0.2s, transform 0.15s;
            padding: 4px 6px;
            border-radius: 6px;
            line-height: 1;
        }
        .delete-btn:hover { opacity: 1; background: rgba(231,76,60,0.12); transform: translateY(-50%) scale(1.15); }

        /* --- Empty state --- */
        .no-reviews {
            text-align: center;
            padding: 32px;
            color: #666;
            font-style: italic;
        }

        /* --- Fade-out animation on delete --- */
        .review-item.removing {
            animation: fadeOut 0.3s ease forwards;
        }
        @keyframes fadeOut {
            to { opacity: 0; transform: translateX(20px); max-height: 0; padding: 0; margin: 0; overflow: hidden; }
        }
    </style>
</head>
<body>

